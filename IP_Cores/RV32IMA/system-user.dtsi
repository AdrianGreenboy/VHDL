/*
 * system-user.dtsi - Paso 7b: reserva de DDR para el SoC HERCOSSNUX
 *
 * Copiar a:
 *   <petalinux-project>/project-spec/meta-user/recipes-bsp/device-tree/files/
 *
 * CAMBIO RESPECTO A LOS IP CORES ANTERIORES: la reserva sube de
 * 16 MB a 64 MB, porque el core RV32IMA modela 64 MB de RAM para
 * el kernel Linux nommu (imagen + DTB + espacio de trabajo).
 *
 * 'no-map' es imprescindible: impide que el kernel del PS mapee
 * la region, de modo que el core de la PL es su unico dueno.
 *
 * CUIDADO con no-map (aprendido en cores previos): glibc aarch64
 * usa DC ZVA y stp de 128 bits en memset/memcpy, que fallan con
 * SIGBUS sobre regiones no-map. Todo acceso desde el PS debe ser
 * un bucle palabra a palabra sobre punteros volatile.
 */

/ {
	reserved-memory {
		#address-cells = <2>;
		#size-cells = <2>;
		ranges;

		hercossnux_ddr: hercossnux_ddr@70000000 {
			no-map;
			reg = <0x0 0x70000000 0x0 0x04000000>;  /* 64 MB */
		};
	};

	/*
	 * El banco de control del SoC. La consola del kernel invitado
	 * sale por aqui (registro UART_RX en el offset 0x10), asi que
	 * no hace falta ningun UART adicional en la PL.
	 */
	hercossnux_ctrl: hercossnux_ctrl@80000000 {
		compatible = "hercossnux,rv32ima-soc";
		reg = <0x0 0x80000000 0x0 0x00010000>;  /* 64 KB */
		memory-region = <&hercossnux_ddr>;
	};
};
