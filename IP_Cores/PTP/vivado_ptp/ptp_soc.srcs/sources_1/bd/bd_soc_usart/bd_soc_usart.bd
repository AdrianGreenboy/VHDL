              "PS_I2CSYSMON_PERIPHERAL {{ENABLE 1} {IO {PS_MIO 18 .. 19}}}",
              "PS_IRQ_USAGE {{CH0 1} {CH1 1} {CH10 0} {CH11 0} {CH12 0} {CH13 0} {CH14 0} {CH15 0} {CH2 0} {CH3 0} {CH4 0} {CH5 0} {CH6 0} {CH7 0} {CH8 0} {CH9 0}}",
